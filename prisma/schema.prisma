// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. USERS AND ROLES
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password_hash    String
  role             String   @default("STUDENT")
  teacher_code_used String?
  school_id        String?
  created_at       DateTime @default(now())

  profile          Profile?
  courses          Course[]
  posts            Post[]
  comments         Comment[]
  post_likes       PostLike[]
  submissions      AssignmentSubmission[]
  practice_sessions PracticeSession[]
  event_participations EventParticipant[]
  course_enrollments CourseEnrollment[]
  course_messages CourseMessage[]
  lesson_progress LessonProgress[]
  stats            UserStats?
  ai_chats         AiChat[]
  teacher_codes    TeacherCode[]  @relation("TeacherCodes")
  created_codes    TeacherCode[]  @relation("CreatedCodes")
  assignments      Assignment[]
  events           Event[]
  notifications    Notification[]
  notification_receivers NotificationReceiver[]
  school           School?     @relation(fields: [school_id], references: [id])
  created_challenges Challenge[]
  challenge_attempts ChallengeAttempt[]
  user_streak       UserStreak?

  @@index([email])
  @@index([school_id])
}

model TeacherCode {
  id         String   @id @default(uuid())
  code       String   @unique
  school_id  String
  created_by String
  expires_at DateTime
  created_at DateTime @default(now())

  school     School   @relation(fields: [school_id], references: [id])
  teacher    User     @relation("CreatedCodes", fields: [created_by], references: [id])
  users      User[]   @relation("TeacherCodes")

  @@index([code])
  @@index([school_id])
}

// 2. SCHOOLS
model School {
  id         String   @id @default(uuid())
  name       String
  city       String
  created_at DateTime @default(now())

  users          User[]
  teacher_codes  TeacherCode[]
  courses        Course[]
  assignments    Assignment[]
  events         Event[]
  notifications  Notification[]

  @@index([city])
}

// 3. PROFILES
model Profile {
  id              String   @id @default(uuid())
  user_id         String   @unique
  username        String?
  avatar_url      String?
  bio             String?
  grade           String?
  auto_generated  Boolean  @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([username])
}

// 4. COURSES (TEACHER ONLY)
model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  image_url   String?
  visibility  String   @default("SCHOOL")
  teacher_id  String
  school_id   String
  created_at  DateTime @default(now())

  teacher   User              @relation(fields: [teacher_id], references: [id])
  school    School            @relation(fields: [school_id], references: [id])
  stages    CourseStage[]
  enrollments CourseEnrollment[]
  assignments Assignment[]

  @@index([teacher_id])
  @@index([school_id])
}

model CourseStage {
  id          String   @id @default(uuid())
  course_id   String
  title       String
  order_index Int
  materials   CourseMaterial[]
  progress   LessonProgress[]

  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([course_id])
}

model CourseMaterial {
  id           String   @id @default(uuid())
  stage_id     String
  type         String
  content_url  String?
  content_text String?

  stage CourseStage @relation(fields: [stage_id], references: [id], onDelete: Cascade)

  @@index([stage_id])
}

model CourseEnrollment {
  id          String   @id @default(uuid())
  course_id   String
  user_id    String
  status     String   @default("PENDING")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chat   CourseChat?

  @@unique([course_id, user_id])
  @@index([course_id])
  @@index([user_id])
  @@index([status])
}

model CourseChat {
  id               String   @id @default(uuid())
  enrollment_id    String   @unique
  messages         CourseMessage[]

  enrollment CourseEnrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
}

model CourseMessage {
  id        String   @id @default(uuid())
  chat_id   String
  sender_id String
  content   String
  created_at DateTime @default(now())

  chat   CourseChat @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [sender_id], references: [id])

  @@index([chat_id])
  @@index([sender_id])
}

model LessonProgress {
  id          String   @id @default(uuid())
  stage_id    String
  user_id     String
  completed   Boolean  @default(false)
  completed_at DateTime?

  stage CourseStage @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([stage_id, user_id])
  @@index([stage_id])
  @@index([user_id])
}

// 5. POSTS (EVERYONE)
model Post {
  id         String   @id @default(uuid())
  author_id  String
  content    String
  image_url  String?
  created_at DateTime @default(now())

  author   User       @relation(fields: [author_id], references: [id])
  likes    PostLike[]
  comments Comment[]

  @@index([author_id])
  @@index([created_at])
}

model PostLike {
  id        String @id @default(uuid())
  user_id   String
  post_id   String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@index([post_id])
}

model Comment {
  id         String   @id @default(uuid())
  post_id    String
  author_id  String
  content    String
  created_at DateTime @default(now())

  post   Post @relation(fields: [post_id], references: [id], onDelete: Cascade)
  author User @relation(fields: [author_id], references: [id])

  @@index([post_id])
  @@index([author_id])
}

// 6. ASSIGNMENTS (TEACHER ONLY)
model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  created_by  String
  school_id   String?
  course_id   String?
  created_at  DateTime @default(now())

  creator     User                @relation(fields: [created_by], references: [id])
  school      School?             @relation(fields: [school_id], references: [id])
  course      Course?             @relation(fields: [course_id], references: [id])
  submissions AssignmentSubmission[]

  @@index([created_by])
  @@index([school_id])
  @@index([course_id])
}

model AssignmentSubmission {
  id           String   @id @default(uuid())
  assignment_id String
  student_id   String
  content      String
  grade        Int?
  feedback     String?
  created_at   DateTime @default(now())

  assignment Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [student_id], references: [id])

  @@index([assignment_id])
  @@index([student_id])
}

// 7. PRACTICE (BUSINESS GAME)
model PracticeLevel {
  id          String   @id @default(uuid())
  title       String
  description String?
  created_by  String
  difficulty  Int
  created_at  DateTime @default(now())

  sessions PracticeSession[]

  @@index([difficulty])
}

model PracticeSession {
  id        String   @id @default(uuid())
  user_id   String
  level_id  String
  balance   Int      @default(0)
  progress  Int      @default(0)
  completed Boolean  @default(false)
  created_at DateTime @default(now())

  user  User          @relation(fields: [user_id], references: [id])
  level PracticeLevel @relation(fields: [level_id], references: [id])

  @@index([user_id])
  @@index([level_id])
}

// DAILY CHALLENGES
model Challenge {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String   // 'quiz', 'coding', 'fill_blank', 'matching'
  difficulty  String   // 'easy', 'medium', 'hard'
  content     String   // JSON with challenge data
  answer      String   // JSON with correct answer
  explanation String?
  xp_reward   Int      @default(10)
  coin_reward Int      @default(5)
  hint        String?
  hint_cost   Int      @default(10)
  active_date DateTime @default(now()) // Date when challenge is active
  created_by  String
  created_at  DateTime @default(now())

  creator User @relation(fields: [created_by], references: [id])
  attempts ChallengeAttempt[]

  @@index([active_date])
  @@index([type])
}

model ChallengeAttempt {
  id          String   @id @default(uuid())
  challenge_id String
  user_id     String
  answer      String
  correct     Boolean
  time_spent  Int      // seconds
  used_hint   Boolean  @default(false)
  xp_earned   Int      @default(0)
  coins_earned Int     @default(0)
  created_at  DateTime @default(now())

  challenge Challenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([challenge_id])
  @@index([user_id])
  @@index([created_at])
}

model UserStreak {
  id          String   @id @default(uuid())
  user_id     String   @unique
  current_streak Int   @default(0)
  longest_streak Int   @default(0)
  last_practice_date DateTime?
  total_practice_days Int @default(0)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// 8. EVENTS (SCHOOL ONLY)
model Event {
  id         String   @id @default(uuid())
  title      String
  description String?
  image_url  String?
  visibility  String   @default("SCHOOL")
  school_id  String
  created_by String
  date       DateTime
  created_at DateTime @default(now())

  school School @relation(fields: [school_id], references: [id])
  creator User  @relation(fields: [created_by], references: [id])
  participants EventParticipant[]

  @@index([school_id])
  @@index([date])
}

model EventParticipant {
  id        String   @id @default(uuid())
  event_id  String
  user_id   String
  joined_at DateTime @default(now())

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@index([event_id])
  @@index([user_id])
}

// 9. NOTIFICATIONS
model Notification {
  id         String   @id @default(uuid())
  title      String
  content    String
  created_by String
  school_id  String?
  created_at DateTime @default(now())

  school    School?                     @relation(fields: [school_id], references: [id])
  creator   User                       @relation(fields: [created_by], references: [id])
  receivers NotificationReceiver[]

  @@index([school_id])
  @@index([created_at])
}

model NotificationReceiver {
  notification_id String
  user_id        String

  notification Notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([notification_id, user_id])
  @@index([user_id])
}

// 10. LEADERBOARD
model UserStats {
  id        String   @id @default(uuid())
  user_id   String   @unique
  xp        Int      @default(0)
  coins     Int      @default(0)
  level     Int      @default(1)
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([xp])
  @@index([coins])
}

// 11. AI ASSISTANT
model AiChat {
  id         String   @id @default(uuid())
  user_id    String
  created_at DateTime @default(now())

  user    User       @relation(fields: [user_id], references: [id])
  messages AiMessage[]

  @@index([user_id])
}

model AiMessage {
  id      String   @id @default(uuid())
  chat_id String
  role    String
  content String
  created_at DateTime @default(now())

  chat AiChat @relation(fields: [chat_id], references: [id], onDelete: Cascade)

  @@index([chat_id])
}
